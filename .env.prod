# ==============================================================================
# Nemo Platform — Production Environment
# ⚠️ NEVER commit this file with real secrets! Use a secrets manager.
# ==============================================================================

# General
NEMO_ENV=production
NEMO_LOG_LEVEL=info
NEMO_LOG_FORMAT=json
DOMAIN=nemo.example.com

# TLS / Let's Encrypt
ACME_EMAIL=admin@nemo.example.com

# PostgreSQL (use strong passwords!)
POSTGRES_USER=nemo
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=nemo

# Redis
REDIS_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# Kafka
KAFKA_BROKERS=kafka:29092
KAFKA_GROUP_ID=nemo-platform

# API Gateway
GATEWAY_JWT_SECRET=CHANGE_ME_USE_STRONG_SECRET_MIN_32_CHARS
GATEWAY_RATE_LIMIT_RPS=50

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Observability
LOKI_URL=http://loki:3100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD

# Frontend
NEXT_PUBLIC_API_URL=https://api.nemo.example.com
NEXT_PUBLIC_WS_URL=wss://api.nemo.example.com
