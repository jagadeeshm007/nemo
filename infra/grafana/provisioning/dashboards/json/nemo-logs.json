{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Log Volume",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({job=\"nemo\"}[1m])) by (container_name)",
          "legendFormat": "{{container_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } } } }
    },
    {
      "title": "Error Logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"nemo\"} |~ \"(?i)(error|panic|fatal|exception)\"",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "sortOrder": "Descending", "enableLogDetails": true }
    },
    {
      "title": "Gateway Logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{job=\"nemo\", container_name=~\".*gateway.*\"}",
          "refId": "A"
        }
      ],
      "options": { "showTime": true, "sortOrder": "Descending", "enableLogDetails": true }
    },
