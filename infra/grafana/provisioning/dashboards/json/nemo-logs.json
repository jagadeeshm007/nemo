  "panels": [
    {
      "title": "Log Volume by Service",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"nemo\"}[1m])) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } } } }
    },
    {
      "title": "Error Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "{job=\"nemo\"} |~ \"(?i)(error|fatal|panic|exception|traceback)\"",
          "refId": "A"
