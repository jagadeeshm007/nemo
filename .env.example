# ==============================================================================
# Nemo Platform — Environment Configuration Template
# Copy to .env and fill in your values
# For dev: cp .env.dev .env
# For prod: cp .env.prod .env
# ==============================================================================

# General
NEMO_ENV=development
NEMO_LOG_LEVEL=debug
NEMO_LOG_FORMAT=json
DOMAIN=nemo.local

# TLS / Let's Encrypt (prod only)
ACME_EMAIL=admin@nemo.example.com

# PostgreSQL
POSTGRES_USER=nemo
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=nemo
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=CHANGE_ME
REDIS_PORT=6380

# Kafka
KAFKA_BROKERS=kafka:29092
KAFKA_GROUP_ID=nemo-platform

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8005

# API Gateway
GATEWAY_HTTP_PORT=8080
GATEWAY_GRPC_PORT=9091
GATEWAY_JWT_SECRET=CHANGE_ME
GATEWAY_RATE_LIMIT_RPS=100

# AI Service
AI_SERVICE_HOST=ai-service
AI_SERVICE_PORT=8001
AI_SERVICE_GRPC_PORT=50051

# Plugin Service
PLUGIN_SERVICE_HOST=plugin-service
PLUGIN_SERVICE_PORT=8002
PLUGIN_SERVICE_GRPC_PORT=50052

# Workflow Service
WORKFLOW_SERVICE_HOST=workflow-service
WORKFLOW_SERVICE_PORT=8003
WORKFLOW_SERVICE_GRPC_PORT=50053

# Vector Service
VECTOR_SERVICE_HOST=vector-service
VECTOR_SERVICE_PORT=8004
VECTOR_SERVICE_GRPC_PORT=50054

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Observability
LOKI_URL=http://loki:3100
PROMETHEUS_PORT=9093
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# Frontend
NEXT_PUBLIC_API_URL=https://api.nemo.local
NEXT_PUBLIC_WS_URL=wss://api.nemo.local
NEXT_PUBLIC_KEYCLOAK_URL=https://auth.nemo.local

# ==============================================================================
# Enterprise Infrastructure
# ==============================================================================

# Temporal (Workflow Orchestration)
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=nemo

# Keycloak (IAM / OAuth2 / OIDC)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME
KEYCLOAK_CLIENT_SECRET=CHANGE_ME

# HashiCorp Vault (Secrets Management)
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=CHANGE_ME

# Unleash (Feature Flags)
UNLEASH_DB_PASSWORD=CHANGE_ME
UNLEASH_ADMIN_TOKEN=CHANGE_ME
UNLEASH_CLIENT_TOKEN=CHANGE_ME
UNLEASH_FRONTEND_TOKEN=CHANGE_ME

# Elasticsearch (Hybrid Search)
ELASTICSEARCH_URL=http://elasticsearch:9200
