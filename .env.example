# ==============================================================================
# Nemo Platform — Environment Configuration
# ==============================================================================

# General
NEMO_ENV=development
NEMO_LOG_LEVEL=debug
NEMO_LOG_FORMAT=json

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=nemo
POSTGRES_PASSWORD=nemo_secret_change_me
POSTGRES_DB=nemo

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_change_me

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_GROUP_ID=nemo-platform

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8005

# API Gateway
GATEWAY_HTTP_PORT=8080
GATEWAY_GRPC_PORT=9090
GATEWAY_JWT_SECRET=change-this-to-a-real-secret-in-production
GATEWAY_RATE_LIMIT_RPS=100

# AI Service
AI_SERVICE_HOST=ai-service
AI_SERVICE_PORT=8001
AI_SERVICE_GRPC_PORT=50051

# Plugin Service
PLUGIN_SERVICE_HOST=plugin-service
PLUGIN_SERVICE_PORT=8002
PLUGIN_SERVICE_GRPC_PORT=50052

# Workflow Service
WORKFLOW_SERVICE_HOST=workflow-service
WORKFLOW_SERVICE_PORT=8003
WORKFLOW_SERVICE_GRPC_PORT=50053

# Vector Service
VECTOR_SERVICE_HOST=vector-service
VECTOR_SERVICE_PORT=8004
VECTOR_SERVICE_GRPC_PORT=50054

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Observability
LOKI_URL=http://loki:3100
PROMETHEUS_PORT=9091
GRAFANA_PORT=3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
