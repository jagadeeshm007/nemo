# ==============================================================================
# Nemo Platform — Development Environment
# ==============================================================================

# General
NEMO_ENV=development
NEMO_LOG_LEVEL=debug
NEMO_LOG_FORMAT=json
DOMAIN=nemo.local

# PostgreSQL
POSTGRES_USER=nemo
POSTGRES_PASSWORD=nemo_dev_secret_2024
POSTGRES_DB=nemo
POSTGRES_PORT=5432

# Redis
REDIS_PASSWORD=redis_dev_secret_2024
REDIS_PORT=6380

# Kafka
KAFKA_BROKERS=kafka:29092
KAFKA_GROUP_ID=nemo-platform

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8005

# API Gateway
GATEWAY_HTTP_PORT=8080
GATEWAY_GRPC_PORT=9091
GATEWAY_JWT_SECRET=dev-jwt-secret-change-in-production-2024
GATEWAY_RATE_LIMIT_RPS=100

# AI Service
AI_SERVICE_HOST=ai-service
AI_SERVICE_PORT=8001
AI_SERVICE_GRPC_PORT=50051

# Plugin Service
PLUGIN_SERVICE_HOST=plugin-service
PLUGIN_SERVICE_PORT=8002
PLUGIN_SERVICE_GRPC_PORT=50052

# Workflow Service
WORKFLOW_SERVICE_HOST=workflow-service
WORKFLOW_SERVICE_PORT=8003
WORKFLOW_SERVICE_GRPC_PORT=50053

# Vector Service
VECTOR_SERVICE_HOST=vector-service
VECTOR_SERVICE_PORT=8004
VECTOR_SERVICE_GRPC_PORT=50054

# LLM Providers (fill in your keys)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Observability
LOKI_URL=http://loki:3100
PROMETHEUS_PORT=9093
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Frontend
NEXT_PUBLIC_API_URL=https://api.nemo.local
NEXT_PUBLIC_WS_URL=wss://api.nemo.local
NEXT_PUBLIC_KEYCLOAK_URL=https://auth.nemo.local

# ==============================================================================
# Enterprise Infrastructure
# ==============================================================================

# Temporal
TEMPORAL_HOST=temporal:7233
TEMPORAL_NAMESPACE=nemo

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_CLIENT_SECRET=nemo-api-secret

# Vault
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=dev-root-token

# Unleash
UNLEASH_DB_PASSWORD=unleash_secret
UNLEASH_ADMIN_TOKEN=*:*.unleash-insecure-admin-api-token
UNLEASH_CLIENT_TOKEN=default:development.unleash-insecure-client-api-token
UNLEASH_FRONTEND_TOKEN=default:development.unleash-insecure-frontend-api-token

# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
